# Backend (copy to backend/.env or set in shell)
DATABASE_URL=sqlite+aiosqlite:///./data/corp_finance.db
SEC_USER_AGENT="CorpFinanceAutopilot/1.0 (your-email@example.com)"
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend (copy to frontend/.env.local)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Docker Compose: same URL is used as default so the browser (on your host) can reach the API port.
